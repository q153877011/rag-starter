# Environment variables for the RAG Agent backend
# Only VITE_ prefixed vars are exposed to browser code

# LLM Gateway Configuration
AI_GATEWAY_API_KEY=your-api-key-here
AI_GATEWAY_BASE_URL=https://api.example.com/v1
AI_GATEWAY_MODEL=model-name

# EdgeOne Pages
EDGEONE_PAGES_API_TOKEN=
OPENAI_AGENTS_DISABLE_TRACING=1
